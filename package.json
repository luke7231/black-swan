{
  "name": "black-swan-ballet-crawler",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "build": "tsc",
    "worker": "node dist/server.js",
    "dev:worker": "npm run build && npm run worker",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "start:prod": "npm run db:migrate:deploy && npm run worker",
    "collect:balletmania": "node scripts/collect-balletmania-employ-list.js",
    "classify:balletmania": "node scripts/classify-balletmania-employ-details.js",
    "collect:esangdance": "node scripts/collect-esangdance-employ-list.js",
    "classify:esangdance": "node scripts/classify-esangdance-employ-details.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "iconv-lite": "^0.6.3",
    "openai": "^6.42.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}
